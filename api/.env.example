# Server
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# Database
# Use 127.0.0.1 for local host connections and localhost for non-Docker environments.
DATABASE_URL="postgresql://reservechain:reservechain@127.0.0.1:5432/reservechain?schema=public"

# Chain sync (TESTNET ONLY). Disabled by default.
CHAIN_SYNC_ENABLED=false
CHAIN_RPC_URL=
CHAIN_ID=11155111            # Sepolia. Mainnet (1) is blocked in code.
TOKEN_ADDRESS=
CHAIN_SYNC_START_BLOCK=0

# Sensitive modules — remain inactive until written authorization
PROOF_OF_RESERVES_ENABLED=false
REDEMPTION_ENABLED=false
