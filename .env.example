# ReserveChain web (working draft)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Waitlist storage:
#  - Leave DATABASE_URL empty to use the local JSON file store (dev only).
#  - Set DATABASE_URL to a PostgreSQL connection string (Vercel Postgres, Neon,
#    Supabase, ...) to persist waitlist registrations in production.
DATABASE_URL=
# Set PGSSL=disable only for a local Postgres without TLS.
PGSSL=
