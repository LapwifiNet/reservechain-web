# ReserveChain ERC-20 — environment (TESTNET ONLY)
# Never commit a real .env. Mainnet deploy is blocked in scripts without written authorization (P20).

SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_KEY
PRIVATE_KEY=0xYOUR_TESTNET_DEPLOYER_KEY
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_KEY

# Admin should be a Gnosis Safe multisig address (holds DEFAULT_ADMIN_ROLE).
ADMIN_ADDRESS=0xYourGnosisSafeMultisig
TREASURY_ADDRESS=0xYourTreasuryAddress

# Token parameters — ILLUSTRATIVE defaults; confirm with issuer before any real deploy.
TOKEN_NAME=ReserveChain Metals Token
TOKEN_SYMBOL=RCM
TOKEN_CAP=100000000000000000000000000
TOKEN_INITIAL_MINT=0

# For GrantRoles.s.sol (dev/testnet only)
TOKEN_ADDRESS=
MINTER_ADDRESS=
PAUSER_ADDRESS=
